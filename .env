# ────────────────────────────────────────────────────────────
# Yardie — environment variables
# ────────────────────────────────────────────────────────────

# Resend (transactional email)
# Domain solagon.com must be verified in the Resend dashboard
# (SPF + DKIM + DMARC records added) for `forms@solagon.com` to deliver.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Yardie Design <forms@solagon.com>"
RESEND_TO_EMAIL="stone@solagon.com,scott@yardiedesign.com,sky@yardiedesign.com,bill@yardiedesign.com,linda@yardiedesign.com"

# reCAPTCHA v3 (Google) — invisible bot-defence on all public forms.
# Create a v3 site at https://www.google.com/recaptcha/admin/create
# and paste both the site (public) and secret (server) keys here.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""
# Minimum score (0.0–1.0) required to accept a submission. Default 0.5.
RECAPTCHA_MIN_SCORE="0.5"

# Public site URL
NEXT_PUBLIC_SITE_URL="https://www.yardiedesign.com"

# Optional — only if a database is added later (Neon/Postgres)
# DATABASE_URL=""
